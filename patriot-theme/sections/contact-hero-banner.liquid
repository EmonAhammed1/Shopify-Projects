{% comment %}
  Contact Hero Banner Section
  Pixel-perfect replica of the "We're Here To Help" hero banner
  with full customization options for Desktop & Mobile
{% endcomment %}

<style>
  .contact-hero-{{ section.id }} {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;

    /* Desktop settings */
    min-height: {{ section.settings.desktop_min_height }}px;
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
    padding-left: {{ section.settings.desktop_padding_horizontal }}px;
    padding-right: {{ section.settings.desktop_padding_horizontal }}px;
    margin-top: {{ section.settings.desktop_margin_top }}px;
    margin-bottom: {{ section.settings.desktop_margin_bottom }}px;

    background-color: {{ section.settings.background_color }};
  }

  /* Background image layer */
  .contact-hero-{{ section.id }}__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    {% if section.settings.bg_image_opacity < 100 %}
      opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};
    {% endif %}
  }

  /* Dark overlay on top of bg image */
  .contact-hero-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  /* Max-width content wrapper */
  .contact-hero-{{ section.id }}__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Gold top divider line with "CONTACT US" label */
  .contact-hero-{{ section.id }}__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: {{ section.settings.desktop_eyebrow_mb }}px;
  }

  .contact-hero-{{ section.id }}__eyebrow-line {
    display: block;
    width: 50px;
    height: 1px;
    background-color: {{ section.settings.accent_color }};
  }

  .contact-hero-{{ section.id }}__eyebrow-icon {
    color: {{ section.settings.accent_color }};
    font-size: {{ section.settings.desktop_eyebrow_icon_size }}px;
    line-height: 1;
  }

  .contact-hero-{{ section.id }}__eyebrow-text {
    font-family: inherit;
    font-size: {{ section.settings.desktop_eyebrow_font_size }}px;
    font-weight: {{ section.settings.eyebrow_font_weight }};
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }}em;
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
  }

  /* Main heading */
  .contact-hero-{{ section.id }}__heading {
    font-family: inherit;
    font-size: {{ section.settings.desktop_heading_font_size }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    line-height: {{ section.settings.heading_line_height }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}em;
    color: {{ section.settings.heading_color }};
    text-transform: {{ section.settings.heading_text_transform }};
    margin: 0 0 {{ section.settings.desktop_heading_mb }}px 0;
  }

  /* Subtext / description */
  .contact-hero-{{ section.id }}__subtext {
    font-family: inherit;
    font-size: {{ section.settings.desktop_subtext_font_size }}px;
    font-weight: {{ section.settings.subtext_font_weight }};
    line-height: {{ section.settings.subtext_line_height }};
    color: {{ section.settings.subtext_color }};
    max-width: {{ section.settings.subtext_max_width }}px;
    margin: 0 auto {{ section.settings.desktop_subtext_mb }}px auto;
  }

  /* Bottom divider with center star/icon */
  .contact-hero-{{ section.id }}__bottom-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .contact-hero-{{ section.id }}__bottom-divider-line {
    display: block;
    width: 50px;
    height: 1px;
    background-color: {{ section.settings.accent_color }};
  }

  .contact-hero-{{ section.id }}__bottom-icon {
    color: {{ section.settings.accent_color }};
    font-size: {{ section.settings.desktop_bottom_icon_size }}px;
    line-height: 1;
  }

  /* =====================
     MOBILE OVERRIDES
  ===================== */
  @media screen and (max-width: 749px) {
    .contact-hero-{{ section.id }} {
      min-height: {{ section.settings.mobile_min_height }}px;
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
      padding-left: {{ section.settings.mobile_padding_horizontal }}px;
      padding-right: {{ section.settings.mobile_padding_horizontal }}px;
      margin-top: {{ section.settings.mobile_margin_top }}px;
      margin-bottom: {{ section.settings.mobile_margin_bottom }}px;
    }

    .contact-hero-{{ section.id }}__eyebrow {
      margin-bottom: {{ section.settings.mobile_eyebrow_mb }}px;
    }

    .contact-hero-{{ section.id }}__eyebrow-text {
      font-size: {{ section.settings.mobile_eyebrow_font_size }}px;
    }

    .contact-hero-{{ section.id }}__eyebrow-icon {
      font-size: {{ section.settings.mobile_eyebrow_icon_size }}px;
    }

    .contact-hero-{{ section.id }}__heading {
      font-size: {{ section.settings.mobile_heading_font_size }}px;
      margin-bottom: {{ section.settings.mobile_heading_mb }}px;
    }

    .contact-hero-{{ section.id }}__subtext {
      font-size: {{ section.settings.mobile_subtext_font_size }}px;
      margin-bottom: {{ section.settings.mobile_subtext_mb }}px;
    }

    .contact-hero-{{ section.id }}__bottom-icon {
      font-size: {{ section.settings.mobile_bottom_icon_size }}px;
    }
  }
</style>

<section class="contact-hero-{{ section.id }}">

  {%- if section.settings.background_image != blank -%}
    <img
      class="contact-hero-{{ section.id }}__bg"
      src="{{ section.settings.background_image | image_url: width: 2400 }}"
      alt="{{ section.settings.background_image.alt | escape }}"
      loading="lazy"
      width="2400"
      height="{{ 2400 | divided_by: section.settings.background_image.aspect_ratio | round }}"
    >
  {%- endif -%}

  <div class="contact-hero-{{ section.id }}__overlay"></div>

  <div class="contact-hero-{{ section.id }}__inner">

    {%- if section.settings.show_eyebrow -%}
      <div class="contact-hero-{{ section.id }}__eyebrow">
        <span class="contact-hero-{{ section.id }}__eyebrow-line"></span>
        {%- if section.settings.eyebrow_icon != blank -%}
          <span class="contact-hero-{{ section.id }}__eyebrow-icon" aria-hidden="true">
            {{ section.settings.eyebrow_icon }}
          </span>
        {%- endif -%}
        {%- if section.settings.eyebrow_text != blank -%}
          <span class="contact-hero-{{ section.id }}__eyebrow-text">
            {{ section.settings.eyebrow_text }}
          </span>
        {%- endif -%}
        {%- if section.settings.eyebrow_icon != blank -%}
          <span class="contact-hero-{{ section.id }}__eyebrow-icon" aria-hidden="true">
            {{ section.settings.eyebrow_icon }}
          </span>
        {%- endif -%}
        <span class="contact-hero-{{ section.id }}__eyebrow-line"></span>
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="contact-hero-{{ section.id }}__heading">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="contact-hero-{{ section.id }}__subtext">
        {{ section.settings.subtext }}
      </p>
    {%- endif -%}

    {%- if section.settings.show_bottom_divider -%}
      <div class="contact-hero-{{ section.id }}__bottom-divider">
        <span class="contact-hero-{{ section.id }}__bottom-divider-line"></span>
        {%- if section.settings.bottom_icon != blank -%}
          <span class="contact-hero-{{ section.id }}__bottom-icon" aria-hidden="true">
            {{ section.settings.bottom_icon }}
          </span>
        {%- endif -%}
        <span class="contact-hero-{{ section.id }}__bottom-divider-line"></span>
      </div>
    {%- endif -%}

  </div>
</section>

