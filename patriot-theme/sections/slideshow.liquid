          "label": "Text"
        },
        {
          "type": "color",
          "id": "custom_colors_solid_button_background",
          "default": "#dd1d1d",
          "label": "Solid button background"
        },
        {
          "type": "color",
          "id": "custom_colors_solid_button_text",
          "default": "#ffffff",
          "label": "Solid button label"
        },
        {
          "type": "color",
          "id": "custom_colors_outline_button",
          "default": "#dd1d1d",
          "label": "Outline button"
        }
      ]
    },
    {
      "type": "anniversary_slide",
      "name": "🎖️ Anniversary Slide",
      "limit": 3,
      "settings": [
        {
          "type": "header",
          "content": "── IMAGES ──"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image (desktop)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Background image (mobile)",
          "info": "If empty, the desktop image is used on mobile."
        },
        {
          "type": "range",
          "id": "image_overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Image overlay opacity",
          "default": 30
        },
        {
          "type": "header",
          "content": "── LAYOUT ──"
        },
        {
          "type": "select",
          "id": "vertical_align",
          "label": "Vertical alignment",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ],
          "default": "center"
        },
        {
          "type": "select",
